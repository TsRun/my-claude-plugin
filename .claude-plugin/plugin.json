{
  "name": "tsrun-toolkit",
  "description": "Dev workflow skills (commit, fix-types, doc) with Obsidian and Playwright MCP integrations.",
  "version": "1.3.0",
  "author": { "name": "Mathis Serrier" },
  "userConfig": {
    "obsidian_port": {
      "title": "Obsidian Port",
      "description": "Obsidian REST API port (default: 27124)",
      "type": "string",
      "sensitive": false
    },
    "obsidian_api_key": {
      "title": "Obsidian API Key",
      "description": "Obsidian Local REST API key (from plugin settings)",
      "type": "string",
      "sensitive": false
    }
  },
  "mcpServers": {
    "obsidian": {
      "command": "uvx",
      "args": ["mcp-obsidian"],
      "env": {
        "OBSIDIAN_API_KEY": "${user_config.obsidian_api_key}",
        "OBSIDIAN_PORT": "${user_config.obsidian_port}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  }
}
